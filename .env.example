# Optional overrides — copy to .env and edit as needed
# cp .env.example .env

# Database
POSTGRES_DB=filevault
POSTGRES_USER=filevault
# Generate a strong password for non-local deployments: openssl rand -base64 32
POSTGRES_PASSWORD=change-me-generate-a-strong-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Django
# Generate: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me-generate-a-long-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,backend-prod
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080

# Gunicorn (production profile)
GUNICORN_WORKERS=2

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=30
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Refresh cookie (auto-secure when DJANGO_DEBUG=False; override if needed)
REFRESH_COOKIE_SECURE=
REFRESH_COOKIE_SAMESITE=Lax

# File storage
FILE_STORAGE_PATH=/app/storage/uploads
MAX_UPLOAD_SIZE_MB=10
MAX_STORAGE_QUOTA_MB=100

# Frontend
VITE_API_URL=http://localhost:8000/api
